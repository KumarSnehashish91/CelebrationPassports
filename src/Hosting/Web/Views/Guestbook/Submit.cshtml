@model CelebrationPassports.Web.Models.Guestbook.GuestbookChapterInfoViewModel

@{
    ViewData["Title"] = "Sign the Guestbook";
    Layout = null;

    var isInvalid = ViewData["InvalidLink"] is true || Model is null;
    var chapterId = ViewData["ChapterId"] as Guid?;
    var token = ViewData["Token"] as string;
    var error = ViewData["SubmitError"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="~/css/pages/guestbook.css" rel="stylesheet" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    <div class="gb-page">
        <div class="gb-card">

            @if (isInvalid)
            {
                <div class="gb-invalid">
                    <i class="bi bi-link-45deg"></i>
                    <h1>This link isn't valid</h1>
                    <p class="gb-sub">It may have been typed incorrectly, or the memory it points to no longer exists.</p>
                </div>
            }
            else
            {
                <div class="gb-stamp"><i class="bi bi-award-fill"></i></div>
                <div class="gb-eyebrow">Guestbook</div>
                <h1>@Model.ChapterTitle</h1>
                <p class="gb-sub">@Model.EventDate.ToString("MMMM dd, yyyy") &middot; Leave a note for this memory</p>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="gb-error">@error</div>
                }

                <form asp-action="Submit" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="chapterId" value="@chapterId" />
                    <input type="hidden" name="token" value="@token" />

                    <div class="gb-field">
                        <label>Your Name</label>
                        <input type="text" name="guestName" maxlength="100" required />
                    </div>

                    <div class="gb-field">
                        <label>Your Note (optional)</label>
                        <textarea name="message" rows="3" maxlength="500" placeholder="Leave a wish, a memory, anything you'd like..."></textarea>
                    </div>

                    <div class="gb-field">
                        <label>Add a Photo (optional)</label>
                        <input type="file" name="photo" accept=".jpg,.jpeg,.png,.webp,.heic" />
                        <p class="gb-hint">JPG, PNG, WEBP, or HEIC — up to 5MB.</p>
                    </div>

                    <button type="submit" class="gb-submit">Sign the Guestbook</button>

                    <p class="gb-hint" style="text-align:center;margin-top:14px;">
                        Your note won't be visible until the passport owner reviews it.
                    </p>
                </form>
            }

        </div>
    </div>

</body>
</html>
