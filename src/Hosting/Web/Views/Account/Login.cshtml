@model CelebrationPassports.Web.Models.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="~/css/pages/account.css"
          rel="stylesheet"
          asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head>

<body>

    <div class="register-page">

        <!-- LEFT PANEL -->

        <section class="hero-panel">

            <div class="hero-content">

                <div class="logo-circle">

                    <i class="bi bi-award-fill"></i>

                </div>

                <span class="hero-tag">

                    CELEBRATION PASSPORT

                </span>

                <h1>

                    Every Memory
                    Deserves a Stamp.

                </h1>

                <p>

                    Birthdays. Anniversaries. Trips. Memories. Wishes. Budgets.
                    One place for everything.

                </p>

                <div class="feature-list">

                    <div class="feature-item">

                        🎂 Birthday Planner

                    </div>

                    <div class="feature-item">

                        💍 Anniversary Reminder

                    </div>

                    <div class="feature-item">

                        ✈ Trip Planner

                    </div>

                    <div class="feature-item">

                        📸 Memory Timeline

                    </div>

                </div>

            </div>

        </section>

        <!-- RIGHT PANEL -->

        <section class="form-panel">

            <div class="register-card">

                <h2>

                    Welcome Back

                </h2>

                <p class="subtitle">

                    Sign in to continue your event journey.

                </p>

                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success mb-3">

                        @ViewBag.SuccessMessage

                    </div>
                }

                <form asp-action="Login"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-4">

                        <label asp-for="Email"></label>

                        <input asp-for="Email"
                               class="form-control" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Password"></label>

                        <input asp-for="Password"
                               class="form-control" />

                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="form-check mb-4">

                        <input asp-for="RememberMe"
                               class="form-check-input" />

                        <label asp-for="RememberMe"
                               class="form-check-label">

                            Remember Me

                        </label>

                    </div>

                    <button class="btn-register"
                            type="submit">

                        Sign In

                    </button>

                </form>

                <div class="acct-divider">
                    <div class="line"></div>
                    <span>or continue via secure channels</span>
                    <div class="line"></div>
                </div>

                <div class="oauth-row" title="Coming soon">
                    <div class="oauth-btn">
                        <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.26 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.85A11 11 0 0012 23z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 010-4.2V7.05H2.18a11 11 0 000 9.9l3.66-2.85z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1a11 11 0 00-9.82 6.05l3.66 2.85C6.71 7.31 9.14 5.38 12 5.38z"/></svg>
                        Google
                    </div>
                    <div class="oauth-btn">
                        <svg viewBox="0 0 24 24" fill="#1E2937"><path d="M16.365 1.43c0 1.14-.462 2.163-1.219 2.933-.827.858-2.15 1.482-3.199 1.4-.14-1.084.44-2.235 1.196-2.978.826-.87 2.24-1.51 3.222-1.355zM20.6 17.44c-.548 1.267-.81 1.834-1.514 2.951-.985 1.56-2.372 3.503-4.093 3.518-1.533.014-1.928-1.002-4.006-.99-2.078.01-2.514 1.006-4.05.99-1.72-.016-3.033-1.767-4.018-3.328C.05 16.87-.532 12.14 1.36 9.108c1.03-1.652 2.87-2.7 4.834-2.72 1.63-.017 3.166 1.11 4.14 1.11.972 0 2.83-1.37 4.775-1.17.813.033 3.096.328 4.56 2.475-.117.074-2.72 1.596-2.697 4.75.028 3.767 3.293 5.02 3.33 5.037-.027.08-.522 1.813-1.702 3.58z"/></svg>
                        Apple
                    </div>
                </div>

                <div class="login-link">

                    Don't have an account?

                    <a asp-action="Register">

                        Create Passport

                    </a>

                </div>

            </div>

        </section>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>

</html>