@model CelebrationPassports.Web.Models.Account.RegisterViewModel

@{
    ViewData["Title"] = "Create Your Celebration Passport";
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="~/css/pages/account.css"
          rel="stylesheet" asp-append-version="true" />

</head>

<body>

    <div class="register-page">

        <!-- LEFT PANEL -->

        <section class="hero-panel">

            <div class="hero-content">

                <div class="logo-circle">

                    CP

                </div>

                <span class="hero-tag">

                    CELEBRATION PASSPORT

                </span>

                <h1>

                    Every event
                    deserves
                    a passport.

                </h1>

                <p>

                    Birthdays.

                    Anniversaries.

                    Trips.

                    Memories.

                    Wishes.

                    Budgets.

                    One place for everything.

                </p>

                <div class="feature-list">

                    <div class="feature-item">

                        🎂 Birthday Planner

                    </div>

                    <div class="feature-item">

                        💍 Anniversary Reminder

                    </div>

                    <div class="feature-item">

                        ✈ Trip Planner

                    </div>

                    <div class="feature-item">

                        📸 Memory Timeline

                    </div>

                </div>

            </div>

        </section>

        <!-- RIGHT PANEL -->

        <section class="form-panel">

            <div class="register-card">

                <h2>

                    Create Your Celebration Passport

                </h2>

                <p class="subtitle">

                    Join today and never miss life's beautiful moments.

                </p>
                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success mb-4">
                        @ViewBag.SuccessMessage
                    </div>
                }

                <form asp-action="Register"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="row">

                        <div class="col-md-6">

                            <div class="mb-4">

                                <label asp-for="FirstName"></label>

                                <input asp-for="FirstName"
                                       class="form-control" />

                                <span asp-validation-for="FirstName"
                                      class="text-danger"></span>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="mb-4">

                                <label asp-for="LastName"></label>

                                <input asp-for="LastName"
                                       class="form-control" />

                                <span asp-validation-for="LastName"
                                      class="text-danger"></span>

                            </div>

                        </div>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Email"></label>

                        <input asp-for="Email"
                               class="form-control" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Password"></label>

                        <input asp-for="Password"
                               class="form-control" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="ConfirmPassword"></label>

                        <input asp-for="ConfirmPassword"
                               class="form-control" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"></span>

                    </div>

                    <button class="btn-register"
                            type="submit">

                        Create Passport

                    </button>

                </form>

                <div class="login-link">

                    Already have an account?

                    <a asp-action="Login">

                        Sign In

                    </a>

                </div>

            </div>

        </section>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>

</html>