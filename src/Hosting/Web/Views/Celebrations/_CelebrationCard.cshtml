@model CelebrationPassports.Web.Models.Events.CelebrationListItemViewModel
@using CelebrationPassports.Web.Models.Events

@{
    // Mirrors CelebrationPassports.Persistence.Enums.EventStatus (Draft=1, Upcoming=2,
    // Ongoing=3, Completed=4, Cancelled=5) — duplicated as a plain mapping since Web no
    // longer references Persistence directly.
    var (statusLabel, statusClass) = Model.Status switch
    {
        1 => ("Draft", "draft"),
        2 => ("Upcoming", "upcoming"),
        3 => ("Ongoing", "ongoing"),
        4 => ("Past", "past"),
        5 => ("Cancelled", "cancelled"),
        _ => ("Event", "upcoming")
    };

    var typeLabel = EventTypeOption.All.FirstOrDefault(o => o.Value == Model.EventType)?.Label ?? "Event";
}

@{
    // Draft events continue through the creation wizard; anything already
    // published (Upcoming/Ongoing/Completed) opens the read-only Preview page
    // instead of dropping the user back into edit forms.
    var linkAction = Model.Status == 1 ? "Create" : "Preview";
}

<a asp-controller="Events" asp-action="@linkAction" asp-route-id="@Model.Id" class="celebration-card">

    <div class="celebration-image">

        <img src="@Model.ImageUrl" alt="@Model.Title" />

        <button class="favorite-btn" type="button">
            <i class="bi bi-heart"></i>
        </button>

    </div>

    <div class="celebration-content">

        <h3>@Model.Title</h3>

        <span class="status @statusClass">
            @statusLabel
        </span>

        <p>
            @typeLabel event
        </p>

        <div class="celebration-footer">

            <span>
                <i class="bi bi-tag"></i>
                @typeLabel
            </span>

            <button class="more-btn" type="button">

                <i class="bi bi-three-dots-vertical"></i>

            </button>

        </div>

    </div>

    <div class="celebration-date">

        <span class="month">
            @Model.StartDate.ToString("MMM").ToUpper()
        </span>

        <span class="day">
            @Model.StartDate.ToString("dd")
        </span>

        <span class="year">
            @Model.StartDate.ToString("yyyy")
        </span>

    </div>

</a>
