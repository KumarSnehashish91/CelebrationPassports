@model List<CelebrationPassports.Web.Models.Events.CelebrationListItemViewModel>

@{
    ViewData["Title"] = "Events";
    var activeTab = ViewData["ActiveTab"] as string ?? "all";
}

<div class="celebration-page">

    <!-- ========================= -->
    <!-- Page Header -->
    <!-- ========================= -->

    <div class="celebration-header">

        <div>

            <h1>Events</h1>

            <p>
                Manage all your special moments in one place.
            </p>

        </div>

        <div style="display:flex;gap:10px;">
            <a asp-controller="TripPlanner" asp-action="Index" class="btn-wizard-secondary">
                <i class="bi bi-airplane"></i>
                Trip Planner
            </a>

            <a asp-controller="Events" asp-action="Create" class="btn-new-celebration">
                <i class="bi bi-plus-lg"></i>
                New Event
            </a>
        </div>

    </div>


    <!-- ========================= -->
    <!-- Filter Row -->
    <!-- ========================= -->

    <div class="celebration-toolbar">

        <!-- Tabs -->

        <div class="celebration-tabs">

            <a asp-action="Index" asp-route-tab="all" class="@(activeTab == "all" ? "active" : "")">All</a>

            <a asp-action="Index" asp-route-tab="upcoming" class="@(activeTab == "upcoming" ? "active" : "")">Upcoming</a>

            <a asp-action="Index" asp-route-tab="ongoing" class="@(activeTab == "ongoing" ? "active" : "")">Ongoing</a>

            <a asp-action="Index" asp-route-tab="past" class="@(activeTab == "past" ? "active" : "")">Past</a>

            <a asp-action="Index" asp-route-tab="draft" class="@(activeTab == "draft" ? "active" : "")">Draft</a>

            <a asp-action="Index" asp-route-tab="cancelled" class="@(activeTab == "cancelled" ? "active" : "")">Cancelled</a>

        </div>


        <!-- Search + Filter -->

        <div class="toolbar-actions">

            <div class="search-box">

                <i class="bi bi-search"></i>

                <input type="text"
                       placeholder="Search events..." />

            </div>

            <button class="toolbar-btn">

                <i class="bi bi-funnel"></i>

                Filter

            </button>

            <button class="toolbar-btn">

                <i class="bi bi-arrow-down-up"></i>

                Sort

            </button>

        </div>

    </div>



    <!-- ========================= -->
    <!-- Cards -->
    <!-- ========================= -->

    @if (Model.Count == 0)
    {
        <div class="celebration-empty">
            <i class="bi bi-calendar-heart"></i>
            <h3>No events here yet</h3>
            <p>@(activeTab == "all" ? "Create your first event to get started." : $"You don't have any {activeTab} events yet.")</p>
            <a asp-controller="Events" asp-action="Create" class="btn-new-celebration">
                <i class="bi bi-plus-lg"></i>
                New Event
            </a>
        </div>
    }
    else
    {
        <div class="event-list">

            @foreach (var item in Model)
            {
                <partial name="_EventRow" model="item" />
            }

        </div>
    }

</div>
