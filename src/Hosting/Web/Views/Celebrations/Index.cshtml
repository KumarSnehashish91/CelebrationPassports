@{
    ViewData["Title"] = "Celebrations";
}

<div class="celebration-page">

    <!-- ========================= -->
    <!-- Page Header -->
    <!-- ========================= -->

    <div class="celebration-header">

        <div>

            <h1>Celebrations</h1>

            <p>
                Manage all your special moments in one place.
            </p>

        </div>

        <button class="btn-new-celebration">
            <i class="bi bi-plus-lg"></i>
            New Celebration
        </button>

    </div>


    <!-- ========================= -->
    <!-- Filter Row -->
    <!-- ========================= -->

    <div class="celebration-toolbar">

        <!-- Tabs -->

        <div class="celebration-tabs">

            <button class="active">All</button>

            <button>Upcoming</button>

            <button>Past</button>

            <button>Draft</button>

            <button>Cancelled</button>

        </div>


        <!-- Search + Filter -->

        <div class="toolbar-actions">

            <div class="search-box">

                <i class="bi bi-search"></i>

                <input type="text"
                       placeholder="Search celebrations..." />

            </div>

            <button class="toolbar-btn">

                <i class="bi bi-funnel"></i>

                Filter

            </button>

            <button class="toolbar-btn">

                <i class="bi bi-arrow-down-up"></i>

                Sort

            </button>

        </div>

    </div>



    <!-- ========================= -->
    <!-- Cards (Next Step) -->
    <!-- ========================= -->

    <div class="celebration-grid">

        <partial name="_CelebrationCard" />

        <partial name="_CelebrationCard" />

        <partial name="_CelebrationCard" />

        <partial name="_CelebrationCard" />

        <partial name="_CelebrationCard" />

        <partial name="_CelebrationCard" />

    </div>

</div>