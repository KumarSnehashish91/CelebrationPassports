@model List<CelebrationPassports.Web.Models.MemoryMap.ThenVsNowPairViewModel>

@{
    ViewData["Title"] = "Then vs. Now";
}

<div class="wizard-page">

    <div class="wizard-header">
        <div class="wizard-header-top">
            <div>
                <h1>Then vs. Now</h1>
                <p>Places you've returned to, years apart.</p>
            </div>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="celebration-empty">
            <i class="bi bi-arrow-repeat"></i>
            <h3>No comparisons yet</h3>
            <p>
                Once you have geo-tagged chapters at the same place in two different
                years, they'll show up here side by side.
            </p>
        </div>
    }
    else
    {
        <div class="tvn-list">
            @foreach (var pair in Model)
            {
                <div class="wizard-card tvn-pair-card">
                    <div class="tvn-pair-head">
                        <h4><i class="bi bi-geo-alt"></i> @pair.PlaceLabel</h4>
                        <span class="tvn-years-apart">@pair.YearsApart @(pair.YearsApart == 1 ? "year" : "years") apart</span>
                    </div>

                    <div class="tvn-pair">
                        <a asp-controller="Stories" asp-action="Chapter" asp-route-id="@pair.Earlier.ChapterId" class="tvn-side">
                            <div class="tvn-photo" style="background-image:url('@(pair.Earlier.ImageUrl ?? "/images/udaipur.jpg")');">
                                <span class="tvn-year-badge">@pair.Earlier.EventDate.Year</span>
                            </div>
                            <div class="tvn-caption">
                                <strong>@pair.Earlier.Title</strong>
                                <span>@pair.Earlier.EventDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </a>

                        <div class="tvn-arrow"><i class="bi bi-arrow-right"></i></div>

                        <a asp-controller="Stories" asp-action="Chapter" asp-route-id="@pair.Later.ChapterId" class="tvn-side">
                            <div class="tvn-photo" style="background-image:url('@(pair.Later.ImageUrl ?? "/images/udaipur.jpg")');">
                                <span class="tvn-year-badge now">@pair.Later.EventDate.Year</span>
                            </div>
                            <div class="tvn-caption">
                                <strong>@pair.Later.Title</strong>
                                <span>@pair.Later.EventDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }

</div>
