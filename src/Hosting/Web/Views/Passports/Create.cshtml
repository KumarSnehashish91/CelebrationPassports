@model CelebrationPassports.Web.Models.Passports.CreatePassportViewModel

@{
    ViewData["Title"] = "Create Passport";
}

<div class="dashboard">

    <div class="dashboard-card" style="padding: 24px; max-width: 480px;">

        <div class="card-header">
            <h4>Create Your Passport</h4>
        </div>

        <p>A Passport is where you'll collect your events, stories, and memories together.</p>

        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" placeholder="e.g. Our Life Together" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <button class="primary-btn" type="submit" style="width:auto;">Create Passport</button>

        </form>

    </div>

</div>
