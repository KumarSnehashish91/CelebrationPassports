@model List<CelebrationPassports.Web.Models.Search.SearchResultViewModel>

@{
    ViewData["Title"] = "Search";
    var query = ViewData["Query"] as string ?? "";
}

<div class="wizard-page">

    <div class="wizard-header">
        <div class="wizard-header-top">
            <div>
                <h1>Search</h1>
                <p>
                    @if (string.IsNullOrWhiteSpace(query))
                    {
                        @:Search your events, stories, passports, and people.
                    }
                    else
                    {
                        @:Results for "@query"
                    }
                </p>
            </div>
        </div>
    </div>

    <div class="wizard-card">

        <form asp-controller="Search" asp-action="Index" method="get" style="margin-bottom:var(--space-lg);">
            <div class="wizard-field" style="margin-bottom:0;">
                <input type="text" name="q" value="@query" placeholder="Search events, places, people..." autofocus />
            </div>
        </form>

        @if (string.IsNullOrWhiteSpace(query))
        {
            <p class="field-hint">Type at least 2 characters to search.</p>
        }
        else if (query.Length < 2)
        {
            <p class="field-hint">Type at least 2 characters to search.</p>
        }
        else if (Model.Count == 0)
        {
            <p class="field-hint">No matches for "@query" — try a different word.</p>
        }
        else
        {
            <div class="chapter-list">
                @foreach (var result in Model)
                {
                    <a href="@result.Url" class="chapter-row">
                        <div class="chapter-row-icon">
                            <i class="bi @result.Icon"></i>
                        </div>
                        <div class="chapter-row-info">
                            <strong>@result.Title</strong>
                            <span>@result.Type@(string.IsNullOrWhiteSpace(result.Subtitle) ? "" : $" · {result.Subtitle}")</span>
                        </div>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        }

    </div>

</div>
