@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="dashboard-card recent-card">

    <div class="card-header">
        <h4>Recent Chapters</h4>
        <a asp-controller="Stories" asp-action="Index">View All</a>
    </div>

    @if (Model.RecentChapters.Count == 0)
    {
        <div class="activity-list">
            <p class="field-hint" style="margin:12px 0;">
                No chapters yet — <a asp-controller="Stories" asp-action="Create">start a story</a> to see them here.
            </p>
        </div>
    }
    else
    {
        <div class="activity-list">

            @foreach (var chapter in Model.RecentChapters)
            {
                <a asp-controller="Stories" asp-action="Chapter" asp-route-id="@chapter.Id" class="activity-item">

                    <div class="activity-icon @(chapter.Source == 2 ? "purple" : "blue")">
                        <i class="bi @(chapter.Source == 2 ? "bi-stars" : "bi-camera")"></i>
                    </div>

                    <div class="activity-content">
                        <h5>@chapter.Title</h5>
                        <p>@chapter.CategoryName &middot; @chapter.Media.Count photo@(chapter.Media.Count == 1 ? "" : "s")</p>
                    </div>

                    <div class="activity-date-card">
                        <span class="month">@chapter.EventDate.ToString("MMM").ToUpper()</span>
                        <span class="day">@chapter.EventDate.ToString("dd")</span>
                    </div>

                </a>
            }

        </div>
    }

</div>
