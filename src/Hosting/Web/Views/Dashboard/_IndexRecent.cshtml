@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="db-card">

    <div class="db-card-head">
        <h3>Recent Chapters</h3>
        <a asp-controller="Stories" asp-action="Index">View All</a>
    </div>

    @if (Model.RecentChapters.Count == 0)
    {
        <p class="field-hint">
            No chapters yet — <a asp-controller="Stories" asp-action="Create">start a story</a> to see them here.
        </p>
    }
    else
    {
        @foreach (var chapter in Model.RecentChapters)
        {
            <a asp-controller="Stories" asp-action="Chapter" asp-route-id="@chapter.Id" class="db-chapter-item">
                <div class="ic"><i class="bi @(chapter.Source == 2 ? "bi-stars" : "bi-camera")"></i></div>
                <div>
                    <h5>@chapter.Title</h5>
                    <p>@chapter.CategoryName &middot; @chapter.Media.Count photo@(chapter.Media.Count == 1 ? "" : "s")</p>
                </div>
                <div class="db-date-badge">
                    <div class="mon">@chapter.EventDate.ToString("MMM").ToUpper()</div>
                    <div class="day">@chapter.EventDate.ToString("dd")</div>
                </div>
            </a>
        }
    }

</div>
