@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="dashboard-card upcoming-card">

    <div class="card-header">

        <h5><b>Upcoming Events</b></h5>

        <a asp-controller="Celebrations" asp-action="Index">View All</a>

    </div>

    <div class="upcoming-list">

        @foreach (var item in Model.UpcomingCelebrations)
        {
            var daysLeft = (item.Date - DateTime.Today).Days;

            <a asp-controller="Events" asp-action="Create" asp-route-id="@item.Id" class="upcoming-item">

                <img src="@item.ImageUrl"
                     class="celebration-thumb"
                     alt="@item.Title" />

                <div class="upcoming-info">

                    <h6>@item.Title</h6>

                    <span>@item.Type</span>

                </div>

                <div class="upcoming-date">

                    <div class="date-badge">

                        <small>@item.Date.ToString("MMM").ToUpper()</small>

                        <strong>@item.Date.ToString("dd")</strong>

                    </div>

                    <span class="days-left">

                        @(daysLeft > 0 ? $"{daysLeft} days left" : "Today")

                    </span>

                </div>

            </a>
        }

    </div>

    <a asp-controller="Events" asp-action="Create" class="btn btn-outline-primary w-100 mt-3">

        <i class="bi bi-plus-lg"></i>

        Create New Event

    </a>

</div>
