@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="db-card" style="display:flex;flex-direction:column;">

    <div class="db-card-head">
        <h3>Upcoming Events</h3>
        <a asp-controller="Celebrations" asp-action="Index">View All</a>
    </div>

    @if (Model.UpcomingCelebrations.Count == 0)
    {
        <p class="field-hint">No upcoming events yet.</p>
    }
    else
    {
        foreach (var item in Model.UpcomingCelebrations)
        {
            var daysLeft = (item.Date - DateTime.Today).Days;

            <a asp-controller="Events" asp-action="Create" asp-route-id="@item.Id" class="db-event-item">

                <div class="thumb" style="background-image:url('@item.ImageUrl');"></div>

                <div>
                    <div class="name">@item.Title</div>
                    <div class="status">@item.Type</div>
                </div>

                <div class="db-date-badge">
                    <div class="mon">@item.Date.ToString("MMM").ToUpper()</div>
                    <div class="day">@item.Date.ToString("dd")</div>
                    <div class="left">@(daysLeft > 0 ? $"{daysLeft}d left" : "Today")</div>
                </div>

            </a>
        }
    }

    <div style="flex:1;"></div>

    <a asp-controller="Events" asp-action="Create" class="db-btn-outline-full">
        <i class="bi bi-plus-lg"></i> Create New Event
    </a>

</div>
