@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard">

    @if (Model.PendingInvitations.Any())
    {
        <partial name="_IndexInvitations" />
    }

    @if (Model.PendingChapterInvitations.Any())
    {
        <partial name="_IndexChapterInvitations" />
    }

    @if (Model.ShowOnboarding)
    {
        <partial name="_IndexEmptyState" />
    }
    else
    {
        <!-- ===========================
             Stat Strip
        ============================ -->

        <div class="db-stat-strip">

            <div class="db-stat">
                <div class="ic"><i class="bi bi-calendar-event"></i></div>
                <div>
                    <div class="num">@Model.Summary.UpcomingCelebrations</div>
                    <div class="lbl">Upcoming &middot; Next Event</div>
                </div>
            </div>

            <div class="db-stat">
                <div class="ic"><i class="bi bi-envelope"></i></div>
                <div>
                    <div class="num">@Model.Summary.Invitations</div>
                    <div class="lbl">Invitations &middot; Pending</div>
                </div>
            </div>

            <div class="db-stat">
                <div class="ic"><i class="bi bi-patch-check"></i></div>
                <div>
                    <div class="num">@Model.Summary.PassportStamps</div>
                    <div class="lbl">Passport Stamps &middot; Earned</div>
                </div>
            </div>

            <div class="db-stat">
                <div class="ic"><i class="bi bi-camera"></i></div>
                <div>
                    <div class="num">@Model.Summary.Memories</div>
                    <div class="lbl">Memories &middot; Photos &amp; Videos</div>
                </div>
            </div>

            <div class="db-stat">
                <div class="ic"><i class="bi bi-airplane"></i></div>
                <div>
                    <div class="num">@Model.Summary.Trips</div>
                    <div class="lbl">Trips &middot; Places Visited</div>
                </div>
            </div>

            <div class="db-stat">
                <div class="ic"><i class="bi bi-globe-central-south-asia"></i></div>
                <div>
                    <div class="num">@Model.Summary.Countries</div>
                    <div class="lbl">Countries &middot; Explored</div>
                </div>
            </div>

        </div>

        <!-- ===========================
             Row 3: Upcoming | Hero | Timeline
        ============================ -->

        <div class="db-row3">

            <partial name="_IndexUpcoming" />

            <partial name="_IndexMemoryHero" />

            <partial name="_IndexTimeline" />

        </div>

        <!-- ===========================
             Row Bottom: Passports | Chapters | Highlights
        ============================ -->

        <div class="db-row-bottom">

            <partial name="_IndexPassports" />

            <partial name="_IndexRecent" />

            <partial name="_IndexMemoryHighlights" />

        </div>
    }

</div>
