@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel
@using CelebrationPassports.Web.Models.ViewModels

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard">

    <!-- ===========================
         Statistics
    ============================ -->

    <div class="stats-row">

        <partial name="_StatisticCard"
                 model='new StatisticCardViewModel
                 {
                     Title = "Upcoming",
                     Value = Model.Summary.UpcomingCelebrations.ToString(),
                     Description = "Next Celebration",
                     Icon = "bi bi-calendar-event",
                     IconBackground = "#F4F1FF"
                 }' />

<partial name="_StatisticCard"
         model='new StatisticCardViewModel
         {
             Title = "Invitations",
             Value = Model.Summary.Invitations.ToString(),
             Description = "Pending",
             Icon = "bi bi-envelope",
             IconBackground = "#EEF9F0"
         }' />

<partial name="_StatisticCard"
         model='new StatisticCardViewModel
         {
             Title = "Passport Stamps",
             Value = Model.Summary.PassportStamps.ToString(),
             Description = "Countries Visited",
             Icon = "bi bi-patch-check",
             IconBackground = "#FFF3F4"
         }' />

<partial name="_StatisticCard"
         model='new StatisticCardViewModel
         {
             Title = "Memories",
             Value = Model.Summary.Memories.ToString(),
             Description = "Photos & Videos",
             Icon = "bi bi-camera",
             IconBackground = "#EEF7FF"
         }' />

<partial name="_StatisticCard"
         model='new StatisticCardViewModel
         {
             Title = "Trips",
             Value = Model.Summary.Trips.ToString(),
             Description = "Places Visited",
             Icon = "bi bi-airplane",
             IconBackground = "#EEF8FF"
         }' />

<partial name="_StatisticCard"
         model='new StatisticCardViewModel
         {
             Title = "Countries",
             Value = Model.Summary.Countries.ToString(),
             Description = "Explored",
             Icon = "bi bi-globe-central-south-asia",
             IconBackground = "#FFF8EC"
         }' />

</div>

    <!-- ===========================
         Main Dashboard Grid
    ============================ -->

    <div class="dashboard-grid">

        <!-- Row 1 -->
        <div class="grid-upcoming">
            <partial name="_IndexUpcoming" />
        </div>

        <div class="grid-memoryhero">
            <partial name="_IndexMemoryHero" />
        </div>

        <div class="grid-timeline">
            <partial name="_IndexTimeline" />
        </div>

        <!-- Row 2 -->
        @* <div class="grid-today">
            <partial name="_IndexTodaysPlan" />
        </div>

        <div class="grid-actions">
            <partial name="_IndexQuickActions" />
        </div>

        <div class="grid-map">
            <div class="dashboard-card journey-map-placeholder">
                <h3>Journey Map</h3>
                <p>Coming next...</p>
            </div>
        </div> *@

        <!-- Row 3 -->
        <div class="dashboard-bottom-row">

            <div class="grid-recent">
                <partial name="_IndexRecent" />
            </div>

            @* <div class="grid-progress">
                <partial name="_IndexProgress" />
            </div> *@
            <div class="grid-memory-highlights">
                <partial name="_IndexMemoryHighlights" />
            </div>
            @* <div class="grid-actions">
                <partial name="_IndexQuickActions" />
            </div> *@

          

        </div>

        <!-- Row 4 -->
        @* <div class="dashboard-bottom-row">

           

            <div class="grid-wishlist">
                <partial name="_IndexWishlist" />
            </div>

        </div> *@

        <!-- Row 5 -->

        <div class="grid-passport-book">

            <partial name="_IndexPassportBook" />

        </div>
    </div>