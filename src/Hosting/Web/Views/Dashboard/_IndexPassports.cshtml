@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="db-card">

    <div class="db-card-head">
        <h3>My Passports</h3>
        <a asp-controller="Passports" asp-action="Index">View All</a>
    </div>

    @if (Model.Passports.Count == 0)
    {
        <p class="field-hint">No passports yet.</p>
    }
    else
    {
        @foreach (var passport in Model.Passports)
        {
            <a asp-controller="Passports" asp-action="Details" asp-route-id="@passport.Id" class="db-passport-item">
                <div class="ic"><i class="bi bi-award-fill"></i></div>
                <div>
                    <h5>@passport.Title</h5>
                    <p>
                        @passport.Status &middot; @passport.PeopleCount @(passport.PeopleCount == 1 ? "person" : "people")
                        @(passport.IsOwner ? " · Owner" : "")
                    </p>
                </div>
            </a>
        }
    }

</div>
