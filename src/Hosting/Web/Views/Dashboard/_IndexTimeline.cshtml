@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="dashboard-card timeline-card">

    <div class="card-header">
        <h4>Life Journey Timeline</h4>
        <a href="#">View Full Timeline</a>
    </div>

    <div class="timeline-list">

        @foreach (var item in Model.Timeline)
        {
            <div class="timeline-item">

                <div class="timeline-year">

                    <span>@item.Year</span>

                    <strong>@item.Month</strong>

                </div>

                <img src="@item.ImageUrl"
                     class="timeline-image" />

                <div class="timeline-info">

                    <h6>@item.Title</h6>

                    <span>@item.Location</span>

                </div>

                <div class="timeline-stamp"
                     style="background:@item.StampColor">
                </div>

            </div>
        }

    </div>

    <a class="timeline-footer" href="#">
        View All Memories →
    </a>

</div>