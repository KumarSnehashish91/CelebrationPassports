@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="db-card">

    <div class="db-card-head">
        <h3>Life Journey</h3>
        <a asp-controller="Stories" asp-action="Index">Full Timeline</a>
    </div>

    @if (Model.Timeline.Count == 0)
    {
        <p class="field-hint">
            No stories yet — <a asp-controller="Stories" asp-action="Create">start one</a> to begin your timeline.
        </p>
    }
    else
    {
        @foreach (var item in Model.Timeline)
        {
            <a asp-controller="Stories" asp-action="Details" asp-route-id="@item.StoryId" class="db-tl-item">

                <div class="db-tl-date">
                    <div class="yr">@item.Year</div>
                    <div class="mon">@item.Month</div>
                </div>

                <div class="db-tl-thumb" style="background-image:url('@item.ImageUrl');"></div>

                <div class="db-tl-text">
                    <h5>@item.Title</h5>
                    <p>@(string.IsNullOrWhiteSpace(item.Location) ? "No location set" : item.Location)</p>
                </div>

                <div class="db-tl-dot" style="background:@item.StampColor;"></div>

            </a>
        }

        <a asp-controller="Stories" asp-action="Index" class="db-view-all-link">View All Memories &rarr;</a>
    }

</div>
