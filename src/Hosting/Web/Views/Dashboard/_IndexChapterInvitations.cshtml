@model CelebrationPassports.Web.ViewModels.Dashboard.DashboardViewModel

<div class="db-card" style="margin-bottom: 24px;">

    <div class="db-card-head" style="margin-bottom: 12px;">
        <h3 style="font-size:18px;">You've been invited to a memory</h3>
    </div>

    @foreach (var invitation in Model.PendingChapterInvitations)
    {
        <div class="upcoming-item">
            <div>
                <h5 style="margin:0;">@invitation.ChapterTitle</h5>
                <small>Invited to contribute photos &amp; notes to this chapter</small>
            </div>

            <form asp-controller="ChapterInvitations" asp-action="Accept" asp-route-id="@invitation.Id" method="post" style="display:inline; margin-left:auto;">
                <button type="submit" class="primary-btn" style="width:auto; padding: 8px 14px;">Accept</button>
            </form>

            <form asp-controller="ChapterInvitations" asp-action="Decline" asp-route-id="@invitation.Id" method="post" style="display:inline; margin-left: 8px;">
                <button type="submit" class="primary-btn" style="width:auto; padding: 8px 14px; background:#fff; color:var(--text); border:1px solid var(--border);">Decline</button>
            </form>
        </div>
    }

</div>
