@model List<CelebrationPassports.Web.Models.Stories.StoryListItemViewModel>

@{
    ViewData["Title"] = "Memories";
    var pendingDrafts = ViewData["PendingDrafts"] as List<CelebrationPassports.Web.Models.Stories.ChapterDetailViewModel> ?? [];
}

<div class="stories-page">

    <div class="stories-header">
        <div>
            <h1>Memories</h1>
            <p>The stories your celebrations turned into.</p>
        </div>

        <div style="display:flex;gap:10px;">
            <a asp-action="QuickUpload" class="btn-wizard-secondary">
                <i class="bi bi-cloud-arrow-up"></i>
                Upload Photos
            </a>
            <a asp-action="Create" class="btn-new-celebration">
                <i class="bi bi-plus-lg"></i>
                New Story
            </a>
        </div>
    </div>

    @if (pendingDrafts.Count > 0)
    {
        <div class="wizard-card" style="margin-bottom:var(--space-lg);">
            <h4><i class="bi bi-robot"></i> Pending Review (@pendingDrafts.Count)</h4>
            <p class="field-hint">AI detected these from your photos — confirm or discard each one.</p>

            <div class="chapter-list">
                @foreach (var draft in pendingDrafts)
                {
                    <a asp-action="ReviewChapter" asp-route-id="@draft.Id" class="chapter-row">
                        <div class="chapter-row-icon">
                            <i class="bi bi-images"></i>
                        </div>
                        <div class="chapter-row-info">
                            <strong>@draft.Title</strong>
                            <span>@draft.CategoryName &middot; @draft.EventDate.ToString("MMM dd, yyyy") &middot; @draft.Media.Count photos</span>
                        </div>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="celebration-empty">
            <i class="bi bi-book"></i>
            <h3>No stories yet</h3>
            <p>Create your first story to start capturing what happened.</p>
            <a asp-action="Create" class="btn-new-celebration">
                <i class="bi bi-plus-lg"></i>
                New Story
            </a>
        </div>
    }
    else
    {
        <div class="stories-grid">
            @foreach (var story in Model)
            {
                <a asp-action="Details" asp-route-id="@story.Id" class="story-card">
                    <div class="story-card-cover @(string.IsNullOrEmpty(story.CoverImageUrl) ? "no-image" : "")"
                         style="@(!string.IsNullOrEmpty(story.CoverImageUrl) ? $"background-image:url('{story.CoverImageUrl}')" : "")">
                        @if (string.IsNullOrEmpty(story.CoverImageUrl))
                        {
                            <i class="bi bi-images"></i>
                        }
                    </div>
                    <div class="story-card-body">
                        <h3>@story.Title</h3>
                        <span class="story-card-meta">
                            <i class="bi bi-collection"></i> @story.ChapterCount @(story.ChapterCount == 1 ? "chapter" : "chapters")
                        </span>
                        @if (story.StartDate.HasValue)
                        {
                            <span class="story-card-meta">
                                <i class="bi bi-calendar3"></i> @story.StartDate.Value.ToString("MMM dd, yyyy")
                            </span>
                        }
                    </div>
                </a>
            }
        </div>
    }

</div>
