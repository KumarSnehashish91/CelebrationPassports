@model CelebrationPassports.Web.Models.Stories.ChapterDetailViewModel

@{
    ViewData["Title"] = Model.Title;
    var wishes = ViewData["Wishes"] as List<CelebrationPassports.Web.Models.Stories.WishViewModel> ?? [];
    var guestbookToken = ViewData["GuestbookToken"] as string;
    var guestbookPending = ViewData["GuestbookPending"] as List<CelebrationPassports.Web.Models.Guestbook.GuestbookSubmissionViewModel> ?? [];
    var guestbookLink = guestbookToken is null ? null : Url.Action("Submit", "Guestbook", new { chapterId = Model.Id, token = guestbookToken }, Context.Request.Scheme);
    var contributors = ViewData["Contributors"] as List<CelebrationPassports.Web.Models.Sharing.ChapterContributorViewModel> ?? [];
    var chapterInvitations = (ViewData["ChapterInvitations"] as List<CelebrationPassports.Web.Models.Sharing.ChapterInvitationViewModel> ?? [])
        .Where(i => i.Status == "Pending")
        .ToList();
}

<div class="event-preview-page">

    <div class="event-preview-topbar">
        <a asp-action="Details" asp-route-id="@Model.StoryId" class="btn-wizard-secondary">
            <i class="bi bi-arrow-left"></i> Back to @Model.StoryTitle
        </a>
    </div>

    @{
        var photoCount = Model.Media.Count(m => m.Type == 1);
        var videoCount = Model.Media.Count(m => m.Type == 2);
        var audioCount = Model.Media.Count(m => m.Type == 3);
        var countParts = new List<string>();
        if (photoCount > 0) countParts.Add($"{photoCount} {(photoCount == 1 ? "photo" : "photos")}");
        if (videoCount > 0) countParts.Add($"{videoCount} {(videoCount == 1 ? "video" : "videos")}");
        if (audioCount > 0) countParts.Add($"{audioCount} {(audioCount == 1 ? "voice note" : "voice notes")}");
    }

    <div class="wizard-card" style="margin-bottom: var(--space-xl);">
        <h1 style="margin:0 0 6px;font-size:26px;">@Model.Title</h1>
        <p class="field-hint" style="margin:0;">
            @Model.CategoryName &middot; @Model.EventDate.ToString("MMMM dd, yyyy")
            @(countParts.Count > 0 ? " · " + string.Join(", ", countParts) : "")
        </p>
    </div>

    <div class="wizard-card" style="margin-bottom: var(--space-xl);">
        <h4>Add Photos &amp; Voice Notes</h4>
        <form asp-action="UploadMedia" method="post" enctype="multipart/form-data">
            <input type="hidden" name="chapterId" value="@Model.Id" />

            <div class="wizard-field" style="margin-bottom:0;">
                <input type="file" name="files" accept=".jpg,.jpeg,.png,.webp,.heic,.mp3,.wav,.m4a" multiple />
                <p class="field-hint">Photos or short voice notes (MP3, WAV, M4A).</p>
            </div>

            <button type="submit" class="btn-wizard-next" style="margin-top:var(--space-md);">
                <i class="bi bi-cloud-arrow-up"></i> Upload
            </button>
        </form>
    </div>

    <div class="wizard-card">
        <h4>Memories</h4>

        @if (Model.Media.Count == 0)
        {
            <p class="field-hint">No photos or voice notes yet — add some above.</p>
        }
        else
        {
            <div class="chapter-media-grid">
                @foreach (var media in Model.Media.Where(m => m.Type != 3))
                {
                    <div class="chapter-media-item">
                        <img src="@media.Url" alt="@Model.Title" loading="lazy" />
                    </div>
                }
            </div>

            @if (audioCount > 0)
            {
                <div class="voice-note-list">
                    @foreach (var media in Model.Media.Where(m => m.Type == 3))
                    {
                        <div class="voice-note-row">
                            <div class="voice-note-icon"><i class="bi bi-mic-fill"></i></div>
                            <audio controls preload="none" src="@media.Url"></audio>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <div class="wizard-card">
        <h4><i class="bi bi-heart"></i> Wishes from Loved Ones <span class="wish-count">&middot; @wishes.Count</span></h4>

        <form asp-action="AddWish" method="post" class="wish-form">
            <input type="hidden" name="chapterId" value="@Model.Id" />
            <textarea name="text" rows="2" maxlength="1000" placeholder="Leave a wish for this memory..." required></textarea>
            <button type="submit" class="btn-wizard-secondary" style="width:auto;align-self:flex-end;">
                <i class="bi bi-send"></i> Send Wish
            </button>
        </form>

        @if (wishes.Count == 0)
        {
            <p class="field-hint">No wishes yet — be the first to leave one.</p>
        }
        else
        {
            <div class="wish-list">
                @foreach (var wish in wishes)
                {
                    <div class="wish">
                        <div class="wish-av">@wish.AuthorName.Substring(0, 1).ToUpper()</div>
                        <div class="wish-body">
                            <div class="wish-name">@wish.AuthorName</div>
                            <div class="wish-text">@wish.Text</div>
                            <div class="wish-date">@wish.CreatedAt.ToString("MMM dd, yyyy")</div>
                        </div>

        @if (wish.IsMine)
                        {
                            <form asp-action="DeleteWish" method="post" class="wish-delete">
                                <input type="hidden" name="id" value="@wish.Id" />
                                <input type="hidden" name="chapterId" value="@Model.Id" />
                                <button type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="wizard-card">
        <h4><i class="bi bi-music-note-beamed"></i> Chapter Soundtrack</h4>
        <p class="field-hint">Pin a song to this memory — just a title, artist, and a link to play it wherever you stream music.</p>

        @if (!string.IsNullOrWhiteSpace(Model.SongTitle))
        {
            <div class="soundtrack-now-playing">
                <div class="soundtrack-icon"><i class="bi bi-vinyl-fill"></i></div>
                <div class="soundtrack-info">
                    <strong>@Model.SongTitle</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.SongArtist))
                    {
                        <span>@Model.SongArtist</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.SongLinkUrl))
                {
                    <a href="@Model.SongLinkUrl" target="_blank" rel="noopener noreferrer" class="btn-wizard-secondary" style="width:auto;">
                        <i class="bi bi-play-fill"></i> Play
                    </a>
                }
            </div>
        }

        <form asp-action="SetSoundtrack" method="post" class="soundtrack-form">
            <input type="hidden" name="chapterId" value="@Model.Id" />
            <div class="soundtrack-fields">
                <input type="text" name="songTitle" maxlength="200" placeholder="Song title" value="@Model.SongTitle" />
                <input type="text" name="songArtist" maxlength="200" placeholder="Artist" value="@Model.SongArtist" />
                <input type="url" name="songLinkUrl" maxlength="500" placeholder="Link (Spotify, YouTube, Apple Music...)" value="@Model.SongLinkUrl" />
            </div>
            <button type="submit" class="btn-wizard-secondary" style="width:auto;margin-top:var(--space-sm);">
                <i class="bi bi-check-lg"></i> Save Soundtrack
            </button>
        </form>
    </div>

    <div class="wizard-card">
        <h4><i class="bi bi-people"></i> Share This Chapter</h4>
        <p class="field-hint">
            Give someone access to just this memory — like a grandparent or a friend — without
            making them a full member of the whole passport. They'll be able to view this
            chapter and add their own photos and wishes to it.
        </p>

        @if (TempData["InviteError"] is string inviteError)
        {
            <p class="field-hint" style="color:#A03D3D;">@inviteError</p>
        }

        <form asp-action="InviteContributor" method="post" class="wish-form" style="flex-direction:row;align-items:flex-start;">
            <input type="hidden" name="chapterId" value="@Model.Id" />
            <input type="email" name="email" placeholder="their@email.com" required
                   style="flex:1;background:var(--bg-body);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-size:13px;color:var(--text);" />
            <button type="submit" class="btn-wizard-secondary" style="width:auto;">
                <i class="bi bi-send"></i> Invite
            </button>
        </form>

        @if (contributors.Count > 0)
        {
            <h5 style="font-size:13px;color:var(--text-light);text-transform:uppercase;letter-spacing:.03em;margin:var(--space-lg) 0 10px;">
                Has Access &middot; @contributors.Count
            </h5>

            <div class="guestbook-pending-list">
                @foreach (var contributor in contributors)
                {
                    <div class="guestbook-pending-item">
                        <div class="guestbook-pending-body">
                            <strong>@contributor.Name</strong>
                            <span>Contributor since @contributor.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="guestbook-pending-actions">
                            <form asp-action="RemoveContributor" method="post">
                                <input type="hidden" name="chapterId" value="@Model.Id" />
                                <input type="hidden" name="contributorId" value="@contributor.Id" />
                                <button type="submit" class="btn-wizard-secondary" title="Remove access"><i class="bi bi-x-lg"></i></button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

        @if (chapterInvitations.Count > 0)
        {
            <h5 style="font-size:13px;color:var(--text-light);text-transform:uppercase;letter-spacing:.03em;margin:var(--space-lg) 0 10px;">
                Invitation Pending &middot; @chapterInvitations.Count
            </h5>

            <div class="guestbook-pending-list">
                @foreach (var invitation in chapterInvitations)
                {
                    <div class="guestbook-pending-item">
                        <div class="guestbook-pending-body">
                            <strong>@invitation.Email</strong>
                            <span>Waiting for them to accept</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="wizard-card">
        <h4><i class="bi bi-book"></i> Guestbook</h4>
        <p class="field-hint">
            Share this link with anyone — no account needed. They can leave a name, a
            note, and a photo, and it'll wait here for your approval before it shows up
            anywhere.
        </p>

        @if (guestbookLink is not null)
        {
            <div class="wizard-field">
                <input type="text" id="guestbookLinkInput" value="@guestbookLink" readonly onclick="this.select();" />
            </div>

            <button type="button" id="copyGuestbookLinkBtn" class="btn-wizard-secondary" style="margin-bottom:var(--space-lg);">
                <i class="bi bi-clipboard"></i> Copy Link
            </button>
        }

        @if (guestbookPending.Count > 0)
        {
            <h5 style="font-size:13px;color:var(--text-light);text-transform:uppercase;letter-spacing:.03em;margin-bottom:10px;">
                Pending Approval &middot; @guestbookPending.Count
            </h5>

            <div class="guestbook-pending-list">
                @foreach (var submission in guestbookPending)
                {
                    <div class="guestbook-pending-item">
                        @if (!string.IsNullOrWhiteSpace(submission.PhotoUrl))
                        {
                            <img src="@submission.PhotoUrl" alt="Submitted photo" class="guestbook-pending-photo" />
                        }
                        <div class="guestbook-pending-body">
                            <strong>@submission.GuestName</strong>
                            @if (!string.IsNullOrWhiteSpace(submission.Message))
                            {
                                <p>@submission.Message</p>
                            }
                            <span>@submission.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="guestbook-pending-actions">
                            <form asp-controller="Guestbook" asp-action="Approve" method="post">
                                <input type="hidden" name="chapterId" value="@Model.Id" />
                                <input type="hidden" name="submissionId" value="@submission.Id" />
                                <button type="submit" class="btn-wizard-secondary" title="Approve"><i class="bi bi-check-lg"></i></button>
                            </form>
                            <form asp-controller="Guestbook" asp-action="Reject" method="post">
                                <input type="hidden" name="chapterId" value="@Model.Id" />
                                <input type="hidden" name="submissionId" value="@submission.Id" />
                                <button type="submit" class="btn-wizard-secondary" title="Reject"><i class="bi bi-x-lg"></i></button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('copyGuestbookLinkBtn')?.addEventListener('click', function () {
            var input = document.getElementById('guestbookLinkInput');
            var btn = this;

            navigator.clipboard.writeText(input.value).then(function () {
                var original = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
                setTimeout(function () { btn.innerHTML = original; }, 2000);
            });
        });
    </script>
}
