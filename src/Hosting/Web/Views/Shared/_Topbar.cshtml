@inject CelebrationPassports.Web.Interfaces.IGreetingService GreetingService
@inject CelebrationPassports.Web.Interfaces.INotificationService NotificationService
@{
    var notifications = await NotificationService.GetMineAsync(8);
    var unreadCount = notifications.Count(n => !n.IsRead);
}
<div class="topbar-container">

    <div class="topbar-left">

        <h2> @GreetingService.GetGreeting(), @(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "there")! 👋</h2>

        <p>Every event creates a memory that lasts forever.</p>

    </div>

    <div class="topbar-right">

        <div class="search-box">

            <input type="text"
                   placeholder="Search events, places, people..." />

        </div>

        <div class="top-icons">

            <div class="notification-dropdown-wrap" id="notificationDropdown">
                <button type="button">
                    <i class="bi bi-bell-fill"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notification-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                    }
                </button>

                <div class="notification-menu" id="notificationMenu">
                    <div class="notification-menu-header">Notifications</div>

                    @if (notifications.Count == 0)
                    {
                        <div class="notification-empty">You're all caught up.</div>
                    }
                    else
                    {
                        foreach (var n in notifications)
                        {
                            <a asp-controller="Notifications" asp-action="Open" asp-route-id="@n.Id"
                               class="notification-item @(n.IsRead ? "" : "unread")">
                                <strong>@n.Title</strong>
                                <span>@n.Message</span>
                                <small>@n.CreatedOn.ToString("MMM dd, h:mm tt")</small>
                            </a>
                        }
                    }
                </div>
            </div>

            <button> <i class="bi bi-chat-dots-fill"></i></button>

        </div>

        <div class="profile" id="profileDropdown">

            <img src="https://i.pravatar.cc/45" alt="Profile">

            <i class="bi bi-chevron-down profile-arrow"></i>

            <div class="profile-menu" id="profileMenu">

                <a href="#">
                    <i class="bi bi-person"></i>
                    My Profile
                </a>

                <a asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>

                <hr>

                <a href="/Account/Logout" class="logout-link">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>

            </div>

        </div>

    </div>

</div>