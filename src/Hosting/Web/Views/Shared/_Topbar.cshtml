@inject CelebrationPassports.Web.Interfaces.IGreetingService GreetingService
@inject CelebrationPassports.Web.Interfaces.INotificationService NotificationService
@inject CelebrationPassports.Web.Interfaces.IUserProfileService UserProfileService
@{
    var notifications = await NotificationService.GetMineAsync(8);
    var unreadCount = await NotificationService.GetUnreadCountAsync();
    var profile = await UserProfileService.GetProfileAsync();

    var initial = "?";
    if (profile is not null)
    {
        var nameForInitial = string.IsNullOrWhiteSpace(profile.DisplayName) ? profile.FirstName : profile.DisplayName;
        if (!string.IsNullOrWhiteSpace(nameForInitial))
        {
            initial = nameForInitial.Substring(0, 1).ToUpper();
        }
    }
}
<div class="topbar-container">

    <div class="topbar-left">

        <div class="topbar-eyebrow"><i class="bi bi-sun"></i> @GreetingService.GetGreeting()</div>

        <h2>Welcome back, @(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "there")</h2>

        <p class="sub">Every event creates a memory that lasts forever.</p>

    </div>

    <div class="topbar-right">

        <form class="search-box" asp-controller="Search" asp-action="Index" method="get">

            <input type="text"
                   name="q"
                   placeholder="Search events, places, people..." />

        </form>

        <div class="top-icons">

            <div class="notification-dropdown-wrap" id="notificationDropdown">
                <button type="button">
                    <i class="bi bi-bell-fill"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notification-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                    }
                </button>

                <div class="notification-menu" id="notificationMenu">
                    <div class="notification-menu-header">Notifications</div>

                    @if (notifications.Count == 0)
                    {
                        <div class="notification-empty">You're all caught up.</div>
                    }
                    else
                    {
                        foreach (var n in notifications)
                        {
                            <a asp-controller="Notifications" asp-action="Open" asp-route-id="@n.Id"
                               class="notification-item @(n.IsRead ? "" : "unread")">
                                <strong>@n.Title</strong>
                                <span>@n.Message</span>
                                <small>@n.CreatedOn.ToString("MMM dd, h:mm tt")</small>
                            </a>
                        }
                    }
                </div>
            </div>

            <button type="button" title="Coming soon — messaging isn't built yet."> <i class="bi bi-chat-dots-fill"></i></button>

        </div>

        <div class="profile" id="profileDropdown">

            @if (profile is not null && !string.IsNullOrWhiteSpace(profile.ProfilePhotoUrl))
            {
                <img src="@profile.ProfilePhotoUrl" alt="Profile">
            }
            else
            {
                <div class="profile-avatar-initial">@initial</div>
            }

            <i class="bi bi-chevron-down profile-arrow"></i>

            <div class="profile-menu" id="profileMenu">

                <a asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person"></i>
                    My Profile
                </a>

                <a asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>

                <hr>

                <a href="/Account/Logout" class="logout-link">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>

            </div>

        </div>

    </div>

</div>