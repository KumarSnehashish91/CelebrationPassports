@model List<CelebrationPassports.Web.Models.Ideas.SomedayIdeaViewModel>

@{
    ViewData["Title"] = "Someday List";
    var passportId = (Guid)ViewData["PassportId"]!;
}

<div class="dashboard">

    <div class="dashboard-card" style="padding: 24px; max-width: 700px;">

        <div class="card-header">
            <h4><i class="bi bi-lightbulb"></i> Someday List</h4>
        </div>

        <p>Ideas for celebrations you haven't planned yet — turn one into a real event whenever you're ready.</p>

        <form asp-action="Create" method="post" style="display:flex; flex-direction:column; gap:8px; margin-bottom:24px;">
            <input type="hidden" name="passportId" value="@passportId" />
            <input type="text" name="title" class="form-control" placeholder="e.g. Surprise anniversary trip" maxlength="200" required />
            <textarea name="notes" class="form-control" rows="2" placeholder="Notes (optional)" maxlength="2000"></textarea>
            <button type="submit" class="primary-btn" style="width:auto;align-self:flex-start;">
                <i class="bi bi-plus-lg"></i> Add Idea
            </button>
        </form>

        @if (Model.Count == 0)
        {
            <p>No ideas yet — add your first one above.</p>
        }
        else
        {
            <div class="upcoming-list">
                @foreach (var idea in Model)
                {
                    <div class="upcoming-item">
                        <div>
                            <h5 style="margin:0;">@idea.Title</h5>
                            @if (!string.IsNullOrWhiteSpace(idea.Notes))
                            {
                                <small>@idea.Notes</small>
                            }
                        </div>

                        <div style="display:flex; gap:8px; margin-left:auto;">
                            @if (idea.ConvertedToEventId.HasValue)
                            {
                                <a asp-controller="Events" asp-action="Preview" asp-route-id="@idea.ConvertedToEventId" class="btn-wizard-secondary" style="width:auto;">
                                    <i class="bi bi-calendar-check"></i> View Event
                                </a>
                            }
                            else
                            {
                                <form asp-action="ConvertToEvent" method="post">
                                    <input type="hidden" name="id" value="@idea.Id" />
                                    <button type="submit" class="btn-wizard-secondary" style="width:auto;">
                                        <i class="bi bi-arrow-right-circle"></i> Convert to Event
                                    </button>
                                </form>

                                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this idea?');">
                                    <input type="hidden" name="id" value="@idea.Id" />
                                    <button type="submit" class="btn-wizard-secondary" style="width:auto;">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }

    </div>

</div>
