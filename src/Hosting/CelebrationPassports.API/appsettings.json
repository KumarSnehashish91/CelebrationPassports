{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=1469;Database=CelebrationPassports;Username=postgres;Password=admin"
  },
  "Jwt": {
    "Key": "dev-only-signing-key-replace-before-deploy-CelebrationPassports",
